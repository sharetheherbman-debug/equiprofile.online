# Stripe Public Key
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx

# API Base URL (leave empty for same-origin requests)
VITE_API_BASE_URL=

# OAuth Configuration (for external auth)
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=

# Analytics (Optional - won't break if missing)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Environment
VITE_ENV=production

# Frontend Version (set at deploy time)
# v1 = legacy frontend (default)
# v2 = redesigned V2 frontend
VITE_UI_VERSION=v1
