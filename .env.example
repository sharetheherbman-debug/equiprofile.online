# ==============================================================================
# EQUIPROFILE PRODUCTION ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# ==============================================================================

# ==========================================
# CORE CONFIGURATION (Always Required)
# ==========================================

# Application Settings
NODE_ENV=production
PORT=3000
HOST=127.0.0.1

# Base URL (required for OAuth redirects and links)
BASE_URL=https://equiprofile.online

# ==========================================
# Database Configuration
# ==========================================
# Format: mysql://username:password@host:port/database
DATABASE_URL=mysql://equiprofile:password@localhost:3306/equiprofile

# ==========================================
# Authentication & Security
# ==========================================

# JWT Secret (generate with: openssl rand -base64 32)
# CRITICAL: Must be at least 32 characters, randomly generated
JWT_SECRET=your_jwt_secret_here_generate_with_openssl

# Admin email address — auto-granted the admin role on login/signup.
# Replace with the actual owner email. No credentials are hardcoded in the app.
ADMIN_EMAIL=owner@example.com

# Admin Unlock Password
# CRITICAL: MUST be changed in production
# Application will refuse to start with weak passwords in production
# SECURITY: For enhanced security, you can store this as a bcrypt hash
#   Example plaintext: MySecureAdminPass123!
#   Example bcrypt hash: $2b$10$abcdefghijklmnopqrstuvwxyz1234567890ABCDEF
#   Generate hash with: node -e "console.log(require('bcrypt').hashSync('YourPassword', 10))"
ADMIN_UNLOCK_PASSWORD=Ashmor12@

# ==========================================
# FEATURE FLAGS (Enable/Disable Features)
# ==========================================

# Enable Stripe billing and subscriptions
# Set to 'true' to enable, 'false' or leave empty to disable
ENABLE_STRIPE=false

# Enable document uploads and storage
# Set to 'true' to enable, 'false' or leave empty to disable
ENABLE_UPLOADS=false

# Enable PWA service worker (server-side flag, used in vite.config.ts build)
# Set to 'true' to enable offline support and caching
# Default: false (disabled for simple deployment)
ENABLE_PWA=true

# ==========================================
# OAUTH CONFIGURATION (Optional)
# ==========================================

# OAuth Server URL - URL of the OAuth authorization server
# Leave empty to disable OAuth login (email/password auth still works)
OAUTH_SERVER_URL=

# OAuth Application ID - The client ID registered with the OAuth server
# Required if OAUTH_SERVER_URL is set
VITE_APP_ID=

# Owner OpenID - OpenID of the application owner (for admin access)
# If set, this user automatically gets admin role
OWNER_OPEN_ID=

# ==========================================
# STRIPE CONFIGURATION (Required if ENABLE_STRIPE=true)
# ==========================================
# Get from https://dashboard.stripe.com

# Stripe keys
# STRIPE_SECRET_KEY=sk_live_xxxxx
# STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Stripe price IDs for subscription plans
# Pro Plan (up to 5 horses)
# STRIPE_MONTHLY_PRICE_ID=price_xxxxx
# STRIPE_YEARLY_PRICE_ID=price_xxxxx

# Stable Plan (up to 20 horses, team features)
# STRIPE_STABLE_MONTHLY_PRICE_ID=price_xxxxx
# STRIPE_STABLE_YEARLY_PRICE_ID=price_xxxxx

# ==========================================
# UPLOAD/STORAGE CONFIGURATION (Required if ENABLE_UPLOADS=true)
# ==========================================

# Storage Proxy API (for document uploads via proxy service)
# STORAGE_PROXY_URL=https://your-storage-proxy.com
# STORAGE_PROXY_KEY=your_storage_proxy_key

# Local disk storage path (used when ENABLE_UPLOADS=false or proxy is not configured)
# IMPORTANT: In Docker, set this to /app/uploads and mount a named volume there
#   so uploaded files survive container restarts and image upgrades.
#   See docker-compose.yml — the uploads_data volume is pre-configured for this.
# Default (production): /var/www/equiprofile/uploads
# Default (development): ./uploads
# STORAGE_PATH=/app/uploads

# AWS S3 Configuration (legacy - alternative to proxy storage)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=eu-west-2
# AWS_S3_BUCKET=equiprofile-uploads

# ==========================================
# PWA (Progressive Web App) CONFIGURATION
# ==========================================

# Enable PWA service worker (client-side Vite flag, must match ENABLE_PWA above)
# Both ENABLE_PWA and VITE_PWA_ENABLED must be true for PWA to work
# Default: false (disabled for simple deployment)
VITE_PWA_ENABLED=true

# ==========================================
# OPTIONAL FEATURES
# ==========================================

# Optional: OpenAI key enables AI features (chat, weather analysis)
# OPENAI_API_KEY=sk-xxxxx

# Optional: AI model to use for chat/analysis.
# Precedence: ai_model DB siteSettings key > OPENAI_MODEL env var > default (gpt-4o-mini)
# Examples: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
# OPENAI_MODEL=gpt-4o-mini

# Optional: Custom OpenAI-compatible base URL (for proxies or alternative providers)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: HuggingFace key for additional AI model access
# HUGGINGFACE_API_KEY=hf_xxxxx

# Optional: Maps proxy for the ride-tracking / GPS map view
# VITE_MAPS_PROXY_URL=https://your-maps-proxy.com
# VITE_MAPS_API_KEY=your_maps_key

# Email Configuration (SMTP - for notifications and Contact form)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=noreply@equiprofile.online

# Contact form destination address (defaults to SMTP_FROM if not set)
# CONTACT_TO=support@equiprofile.online

# ==========================================
# WHATSAPP CONFIGURATION (Optional)
# ==========================================
# WhatsApp Cloud API integration for sending reminders via WhatsApp
# See docs/WHATSAPP_SETUP.md for complete setup instructions
# Default: disabled (ENABLE_WHATSAPP=false)

# Enable/Disable WhatsApp notifications
# Set to 'true' to enable, 'false' or leave empty to disable
ENABLE_WHATSAPP=false

# WhatsApp Cloud API credentials (from Meta Developer Portal)
# Only required if ENABLE_WHATSAPP=true
# WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
# WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
# WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
# WHATSAPP_APP_ID=your_app_id
# WHATSAPP_APP_SECRET=your_app_secret

# Webhook verification token (generate with: openssl rand -base64 32)
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_random_token_here

# ==========================================
# SECURITY & REVERSE PROXY
# ==========================================

# Rate Limiting Configuration
# Default: 500 requests per 15 minutes per IP (increased from 100 for authenticated dashboard use)
# Consider 1000 for high-traffic production deployments
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500

# Cookie Security (Important when behind reverse proxy)
# Set to your domain for production
# COOKIE_DOMAIN=equiprofile.online
# COOKIE_SECURE=true

# ==========================================
# LOGGING
# ==========================================

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Log file path (ensure directory exists and is writable)
# LOG_FILE_PATH=/var/log/equiprofile/app.log

# ==========================================
# BUILD CONFIGURATION (for build endpoints)
# ==========================================

# Build ID (auto-generated during build)
# BUILD_ID=abc123

# Build timestamp (auto-generated during build)
# BUILD_TIME=2026-01-07T12:00:00.000Z

# ==========================================
# SALES CHAT WIDGET
# ==========================================

# Secret key to access the /api/sales-leads admin endpoint
# Set to a long random string; keep private
# ADMIN_LEADS_KEY=your_secret_random_key_here
